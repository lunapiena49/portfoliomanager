<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31).
    Two channels:
      * cloud-backup: Google Drive Auto Backup. Mirrors backup_rules.xml.
      * device-transfer: phone-to-phone setup (Android Easy Transfer / D2D).

    For both we exclude every persistence surface that carries portfolio
    data, consent state, or secure storage: the Play Store policy expects
    sensitive financial data not to leak through restore flows on a new
    device the user may not own.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="PortfolioManager/" />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
        <exclude domain="sharedpref" path="VGhpcyBpcyB0aGUgcHJlZml4IGZvciBhIHNlY3VyZSBzdG9yYWdlCg.xml" />
        <exclude domain="sharedpref" path="flutter_secure_storage.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="PortfolioManager/" />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
        <exclude domain="sharedpref" path="VGhpcyBpcyB0aGUgcHJlZml4IGZvciBhIHNlY3VyZSBzdG9yYWdlCg.xml" />
        <exclude domain="sharedpref" path="flutter_secure_storage.xml" />
    </device-transfer>
</data-extraction-rules>
