<?xml version="1.0" encoding="utf-8"?>
<!--
    Network policy hardening.

    The base config rejects all cleartext HTTP traffic and trusts only the
    system CA store. This blocks:
      * man-in-the-middle setups using a user-installed CA (e.g. work
        proxies, debug profiles installed without the user's awareness)
      * accidental http:// fallbacks introduced by future code changes

    Domain-scoped overrides intentionally NOT defined: every endpoint the
    app contacts (lunapiena49.github.io for snapshots, generativelanguage.
    googleapis.com for Gemini, eodhd.com, financialmodelingprep.com, plus
    optional secondary providers configurable in Settings) is reachable
    over the system trust chain. If a future release introduces certificate
    pinning, the entries go in <domain-config> blocks below.

    The debug build still uses cleartext for Flutter tooling (hot reload),
    handled by the network-security debug overlay generated by Gradle.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
