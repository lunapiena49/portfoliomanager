# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/
.vs/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android release signing — never commit the keystore or its passwords.
# The keystore lives outside the repo (~/.plurifin/keys/) and key.properties
# is generated by scripts/release/setup_keystore.ps1.
/android/key.properties
/android/app/upload-keystore.jks
/android/app/*.jks
/android/app/*.keystore

# Dart obfuscation symbols archive (de-obfuscation maps for crash reports).
# Stored under build/symbols/ and copied into ~/.plurifin/symbols/<version>/
# by scripts/release/build_release.ps1. Never commit either copy.
/build/symbols/

# Market data artifacts: only commit the lightweight top_movers.json.
# Heavy files (SQLite DB, rolling zip, prices_index) are regenerated by CI
# and published on GitHub Pages — no need to keep them in git history.
/dist/logs/
/dist/market-data/*
!/dist/market-data/top_movers.json
!/dist/market-data/.gitkeep

# Claude Code local overrides (user-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/plan/output/

# Repo-split staging output (generated by scripts/release/build_repo_split.ps1).
# Templates and the script live in scripts/release/repo_split_templates/.
/repo_split/

