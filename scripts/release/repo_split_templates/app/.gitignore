# Portfolio Manager -- private repo .gitignore
# This is the curated .gitignore for the published private repo.
# It mirrors the source repo .gitignore minus the data-only carve-outs.

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/
.vs/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing config (keystore is generated by user, never committed)
/android/key.properties
/android/app/upload-keystore.jks

# Claude Code local overrides
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/plan/output/

# Repo-split staging (only relevant in the source monorepo)
/repo_split/

# Secret scan reports
gitleaks_report.json
